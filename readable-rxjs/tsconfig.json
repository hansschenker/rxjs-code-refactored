{
  "extends": "../upstream-rxjs/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "incremental": false,
    "paths": {
      "chai": ["./upstream-rxjs/node_modules/@types/chai"],
      "rxjs": ["./readable-rxjs/src/index"],
      "rxjs/operators": ["./readable-rxjs/src/operators/index"],
      "rxjs/testing": ["./upstream-rxjs/src/testing/index"],
      "rxjs/ajax": ["./upstream-rxjs/src/ajax/index"],
      "rxjs/webSocket": ["./readable-rxjs/src/webSocket/index"],
      "rxjs/fetch": ["./readable-rxjs/src/fetch/index"],
      "rxjs/internal/operators/*": ["./readable-rxjs/src/operators/*"],
      "rxjs/internal/observable/*": ["./readable-rxjs/src/observable/*"],
      "rxjs/internal/scheduler/*": ["./readable-rxjs/src/scheduler/*"],
      "rxjs/internal/scheduled/*": ["./readable-rxjs/src/scheduled/*"],
      "rxjs/internal/util/lift": ["./readable-rxjs/src/util/lift"],
      "rxjs/internal/util/isObservable": ["./readable-rxjs/src/util/isObservable"],
      "rxjs/internal/Observable": ["./readable-rxjs/src/Observable"],
      "rxjs/internal/Subscriber": ["./readable-rxjs/src/Subscriber"],
      "rxjs/internal/Subscription": ["./readable-rxjs/src/Subscription"],
      "rxjs/internal/Subject": ["./readable-rxjs/src/Subject"],
      "rxjs/internal/BehaviorSubject": ["./readable-rxjs/src/BehaviorSubject"],
      "rxjs/internal/ReplaySubject": ["./readable-rxjs/src/ReplaySubject"],
      "rxjs/internal/AsyncSubject": ["./readable-rxjs/src/AsyncSubject"],
      "rxjs/internal/Scheduler": ["./readable-rxjs/src/Scheduler"],
      "rxjs/internal/Notification": ["./readable-rxjs/src/Notification"],
      "rxjs/internal/NotificationFactories": ["./readable-rxjs/src/NotificationFactories"],
      "rxjs/internal/firstValueFrom": ["./readable-rxjs/src/firstValueFrom"],
      "rxjs/internal/lastValueFrom": ["./readable-rxjs/src/lastValueFrom"],
      "rxjs/internal/config": ["./readable-rxjs/src/config"],
      "rxjs/internal/*": ["./upstream-rxjs/src/internal/*"]
    },
    "typeRoots": ["../upstream-rxjs/node_modules/@types"],
    "types": ["chai", "mocha", "node"],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "spec/**/*.ts"
  ]
}
